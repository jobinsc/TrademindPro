# Optional cloud AI for Agents Hub + Nejoic free-text answers
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Upstox (for real login + later live orders)
UPSTOX_API_KEY=
UPSTOX_API_SECRET=
UPSTOX_REDIRECT_URI=http://localhost:3000/api/broker/upstox/callback

# ========== Nejoic Telegram (updates every 3 minutes) ==========
# STEP 1: Telegram → search @BotFather → /newbot → copy TOKEN
# STEP 2: Open your bot → Start. Get your chat id from @userinfobot
# STEP 3: Put values below in Vercel → Settings → Environment Variables
# STEP 4: Redeploy
# STEP 5: Set webhook (browser address bar):
#   https://api.telegram.org/botYOUR_TOKEN/setWebhook?url=https://YOUR_SITE.vercel.app/api/telegram/webhook?secret=YOUR_SECRET
#
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=jobin_nejoic_secret
TELEGRAM_ALLOWED_CHAT_IDS=
CRON_SECRET=jobin_nejoic_secret
# Optional (same value on both if you want extra lock)
TELEGRAM_NOTIFY_KEY=
NEXT_PUBLIC_TELEGRAM_NOTIFY_KEY=
