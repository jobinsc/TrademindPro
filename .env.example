# Optional cloud AI for Agents Hub + Nejoic free-text answers
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Upstox (for real login + later live orders)
# Local:
UPSTOX_API_KEY=
UPSTOX_API_SECRET=
UPSTOX_REDIRECT_URI=http://localhost:3000/api/broker/upstox/callback
# Production (Vercel) must use:
# UPSTOX_REDIRECT_URI=https://trademind-pro.vercel.app/api/broker/upstox/callback
# Also add the SAME redirect URL in Upstox Developer App settings.

# ========== Live data (always on) ==========
# Watchlist / Holdings / Journal LTP poll every 3 seconds.
# Prefer Upstox token (Terminal → Login). Yahoo is the automatic fallback.
NEXT_PUBLIC_AUTH_MODE=local

# ========== Supabase (cloud login + save across devices) ==========
# 1) Create free project: https://supabase.com
# 2) Project Settings → API → copy Project URL + anon public key
# 3) SQL Editor → paste/run file: supabase/schema.sql
# 4) Authentication → Providers → Email → turn OFF "Confirm email"
# 5) Set NEXT_PUBLIC_AUTH_MODE=cloud and put keys on Vercel, then Redeploy
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ========== Nejoic Telegram ==========
# STEP 1: Telegram → search @BotFather → /newbot → copy TOKEN
# STEP 2: Open your bot → Start. Get your chat id from @userinfobot
# STEP 3: Put values below in Vercel → Settings → Environment Variables
# STEP 4: Redeploy
# STEP 5: Set webhook (browser address bar):
#   https://api.telegram.org/botYOUR_TOKEN/setWebhook?url=https://YOUR_SITE.vercel.app/api/telegram/webhook?secret=YOUR_SECRET
#
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=jobin_nejoic_secret
TELEGRAM_ALLOWED_CHAT_IDS=
CRON_SECRET=jobin_nejoic_secret
# Optional (same value on both if you want extra lock)
TELEGRAM_NOTIFY_KEY=
NEXT_PUBLIC_TELEGRAM_NOTIFY_KEY=
